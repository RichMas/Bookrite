{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "General profile information for all users (customers and providers).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "provider", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Provider": {
      "title": "Service Provider",
      "description": "Detailed information for service providers.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "photoURL": { "type": "string" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "isApproved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "category", "location"]
    },
    "Booking": {
      "title": "Service Booking",
      "description": "Details of a service booking.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "providerId": { "type": "string" },
        "providerName": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "totalAmount": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "providerId", "date", "time", "status"]
    },
    "Review": {
      "title": "Provider Review",
      "description": "Customer feedback for a service provider.",
      "type": "object",
      "properties": {
        "bookingId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "providerId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bookingId", "customerId", "providerId", "rating", "comment"]
    },
    "Chat": {
      "title": "Conversation",
      "description": "Metadata for a chat between two users.",
      "type": "object",
      "properties": {
        "members": { "type": "array", "items": { "type": "string" } },
        "customerName": { "type": "string" },
        "providerName": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["members", "customerName", "providerName"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "Individual message within a conversation.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Main user records."
    },
    "providers/{providerId}": {
      "schema": "Provider",
      "description": "Service provider profiles."
    },
    "bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Booking records."
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Provider reviews."
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "Conversation threads."
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages in a thread."
    }
  }
}
