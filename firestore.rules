rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getAuthEmail() {
      return request.auth.token.email;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role helpers
    function isAdmin() {
      // Bootstrapped admin emails from runtime
      return isSignedIn() && (
        getAuthEmail() == 'paragonbusinessconsult@gmail.com' ||
        getAuthEmail() == 'sithembiledlaza8@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email == getAuthEmail() &&
             (data.role in ['customer', 'provider'] || (data.role == 'admin' && isAdmin())) &&
             data.keys().hasAll(['uid', 'email', 'role']) &&
             data.keys().size() >= 3;
    }

    function isValidProvider(data) {
      return data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.location is string && data.location.size() <= 200 &&
             data.keys().hasAll(['uid', 'name', 'category', 'location']);
    }

    function isValidBooking(data) {
      return data.customerId == request.auth.uid &&
             exists(/databases/$(database)/documents/providers/$(data.providerId)) &&
             data.date is string && data.date.size() == 10 && 
             data.time is string &&
             data.status in ['pending', 'confirmed', 'cancelled', 'completed'] &&
             data.keys().hasAll(['customerId', 'customerName', 'providerId', 'providerName', 'category', 'serviceName', 'date', 'time', 'status', 'totalAmount']);
    }

    function isValidReview(data) {
      return isSignedIn() &&
             data.customerId == request.auth.uid &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() >= 5 && data.comment.size() <= 1000 &&
             data.keys().hasAll(['bookingId', 'customerId', 'customerName', 'providerId', 'rating', 'comment', 'createdAt']);
    }

    function isValidChat(data) {
      return isSignedIn() &&
             request.auth.uid in data.members &&
             data.members.size() == 2 &&
             data.keys().hasAll(['members', 'customerName', 'providerName']);
    }

    function isValidMessage(data) {
      return isSignedIn() &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 2000 &&
             data.keys().hasAll(['senderId', 'text', 'createdAt']);
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']) ||
        isAdmin()
      );
    }

    match /providers/{providerId} {
      allow get: if true;
      allow list: if true;
      allow create: if isOwner(providerId) && isValidProvider(incoming());
      allow update: if (isOwner(providerId) || isAdmin()) && (
        // Providers can't self-verify or change approval status
        (!incoming().diff(existing()).affectedKeys().hasAny(['isApproved', 'isVerified']) && isOwner(providerId)) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (isOwner(existing().customerId) || isOwner(existing().providerId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.customerId == request.auth.uid || resource.data.providerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidBooking(incoming());
      allow update: if isSignedIn() && (
        // Status can only be changed by fixed parties
        (isOwner(existing().customerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == 'cancelled') ||
        (isOwner(existing().providerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status in ['confirmed', 'cancelled', 'completed']) ||
        // Only admin can change payment/payout status
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['paymentStatus', 'payoutStatus'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(incoming()) && 
                    get(/databases/$(database)/documents/bookings/$(incoming().bookingId)).data.status == 'completed' &&
                    get(/databases/$(database)/documents/bookings/$(incoming().bookingId)).data.customerId == request.auth.uid;
      allow update: if false; // Reviews are immutable
      allow delete: if isAdmin() || (isSignedIn() && existing().customerId == request.auth.uid);
    }

    match /chats/{chatId} {
      allow get: if isSignedIn() && request.auth.uid in resource.data.members;
      allow list: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && isValidChat(incoming());
      allow update: if isSignedIn() && request.auth.uid in resource.data.members &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt', 'updatedAt']);
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members && isValidMessage(incoming());
      }
    }

    // System collections
    match /admins/{adminId} {
      allow read: if isAdmin();
    }
  }
}
